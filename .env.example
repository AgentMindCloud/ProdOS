# ProducerOS environment overrides.
# Copy this file to `.env` for local development only. Never commit a real `.env`.
# All values are optional -- ProducerOS works with zero configuration.
# Settings prefixed PRODUCEROS_ map onto src/produceros/config.py (Settings).

# Directory where the SQLite database, secret key, logs, and backups live.
# Defaults to a platform-appropriate user data directory (see docs/INSTALL_WINDOWS.md).
# PRODUCEROS_DATA_DIR=C:\Users\you\AppData\Local\ProducerOS

# Network bind mode: "desktop" (127.0.0.1 only) or "lan" (private-network only).
# PRODUCEROS_BIND_MODE=desktop

# Port for the HTTP server.
# PRODUCEROS_PORT=8420

# Session cookie lifetime, in minutes.
# PRODUCEROS_SESSION_MINUTES=720

# Enable the local MCP server (disabled by default).
# PRODUCEROS_MCP_ENABLED=false

# Path to an ffmpeg/ffprobe binary if not on PATH (optional, auto-detected otherwise).
# PRODUCEROS_FFMPEG_PATH=
# PRODUCEROS_FFPROBE_PATH=

# Log level: DEBUG, INFO, WARNING, ERROR.
# PRODUCEROS_LOG_LEVEL=INFO

# Application environment label shown in logs/UI: development, production.
# PRODUCEROS_ENV=production
